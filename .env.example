# ── Supabase ────────────────────────────────────────────────
# Project URL and anon key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY (route handlers / Edge Functions). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Wallet (wagmi / WalletConnect / Reown) ──────────────────
# Project ID gratuito: https://cloud.reown.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ── Preventa on-chain ───────────────────────────────────────
NEXT_PUBLIC_PRESALE_CONTRACT=
# Decimales del token OPEN (por defecto 18)
NEXT_PUBLIC_OPEN_DECIMALS=18
# Dirección del token OPEN en Base (opcional hasta el TGE; activa el saldo OPEN en la cartera)
NEXT_PUBLIC_OPEN_TOKEN=

# ── RPC ─────────────────────────────────────────────────────
# RPC dedicado para Base (Alchemy/QuickNode). Sin él se usa el público, con rate limits.
NEXT_PUBLIC_RPC_BASE=

# ── Sistema de depósitos (pestaña "Comprar sin wallet") ─────
# Firma la cookie op_buyer del comprador. Genera: openssl rand -hex 32
DEPOSIT_TOKEN_SECRET=
# URL pública del sitio (emails y magic links)
NEXT_PUBLIC_SITE_URL=https://www.openaiprotocol.com

# ── Emails transaccionales (Resend) ─────────────────────────
RESEND_API_KEY=
RESEND_FROM=OPEN <noreply@openaiprotocol.com>

ZEROX_API_KEY=

# ── Relay (puente cross-chain, solo servidor; opcional pero recomendado
#    para límites de peticiones más altos: https://docs.relay.link) ──
RELAY_API_KEY=